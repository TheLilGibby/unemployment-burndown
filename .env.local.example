# =============================================================================
# Local Development — No AWS/Plaid Credentials Needed
# =============================================================================
# Copy this file to .env to run the app with local example data.
# This is ideal for:
#   - Local development without cloud services
#   - GitHub Codespaces / cloud dev environments
#   - CI/CD pipelines
#   - Demo / presentation mode
# =============================================================================

# ── Local data mode ──
# Reads/writes JSON files from examples/ instead of S3.
# No AWS credentials required.
USE_LOCAL_DATA=true

# Optional: override the local data directory (default: examples/)
# LOCAL_DATA_DIR=examples

# ── JWT (any string works for local dev) ──
JWT_SECRET=local-dev-secret-not-for-production-use

# ── Dev auth credentials ──
VITE_APP_USERNAME=admin
VITE_APP_PASSWORD=demo

# ── API URL (tells the frontend where to find the backend) ──
# Leave unset when using `npm run dev` — Vite's proxy handles /api requests.
# Only needed for standalone frontend builds or non-Vite setups.
# VITE_PLAID_API_URL=https://localhost:3001

# ── Application URL (password reset links point here) ──
# In dev mode, reset emails are logged to the server console instead of sent.
APP_URL=http://localhost:5173

# ── Server port ──
PLAID_SERVER_PORT=3001

# =============================================================================
# To pull REAL data from production S3 into examples/:
#
#   1. Add your AWS credentials below (or use AWS_PROFILE)
#   2. Run: npm run pull-examples
#   3. Optionally add --sanitize to strip PII:
#      node scripts/pull-prod-examples.mjs --sanitize
#   4. Optionally specify an org:
#      node scripts/pull-prod-examples.mjs --org org_abc123
#
# AWS_REGION=us-west-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# =============================================================================
