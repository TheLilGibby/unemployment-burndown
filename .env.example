# =============================================================================
# Unemployment Burndown - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# -----------------------------------------------------------------------------
# Plaid API (Banking Integration)
# Sign up at https://plaid.com for credentials
# -----------------------------------------------------------------------------
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_ENV=sandbox
PLAID_SECRET=your-plaid-secret
# Legacy alias (used as fallback if PLAID_SECRET is not set):
# PLAID_SANDBOX_SECRET=your-plaid-sandbox-secret

# -----------------------------------------------------------------------------
# SnapTrade API (Brokerage Integration)
# Sign up at https://snaptrade.com for credentials
# -----------------------------------------------------------------------------
SNAPTRADE_CLIENT_ID=your-snaptrade-client-id
SNAPTRADE_API_SECRET=your-snaptrade-api-secret

# -----------------------------------------------------------------------------
# SendGrid (Email Notifications)
# Sign up at https://sendgrid.com for an API key
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Application URL (used in password reset emails)
# -----------------------------------------------------------------------------
APP_URL=https://your-app-url.com

# -----------------------------------------------------------------------------
# CORS Allowed Origins (comma-separated)
# Restricts which domains can make cross-origin requests to the API.
# Defaults to APP_URL + localhost dev origins if not set.
# -----------------------------------------------------------------------------
# ALLOWED_ORIGINS=https://your-app-url.com,https://www.your-app-url.com

# -----------------------------------------------------------------------------
# JWT Authentication
# Generate a secure random string (minimum 32 characters)
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -----------------------------------------------------------------------------
# Plaid Data Encryption (At-Rest)
# Used to encrypt Plaid access tokens in DynamoDB with AES-256-GCM.
# Generate a secure random string (minimum 32 characters).
# -----------------------------------------------------------------------------
PLAID_ENCRYPTION_KEY=your-plaid-encryption-key-minimum-32-characters

# -----------------------------------------------------------------------------
# App Authentication (Development Only)
# Basic auth for protecting dev/staging environments
# NOTE: VITE_ prefixed vars are embedded in the client bundle
# -----------------------------------------------------------------------------
VITE_APP_USERNAME=admin
VITE_APP_PASSWORD=change-this-password

# -----------------------------------------------------------------------------
# GitHub (Feedback Widget)
# Personal access token with 'repo' scope (or 'public_repo' for public repos)
# Used by the in-app feedback widget to create GitHub issues
# -----------------------------------------------------------------------------
GITHUB_TOKEN=your-github-personal-access-token

# -----------------------------------------------------------------------------
# SnapTrade API (Investment/Brokerage Integration)
# Sign up at https://snaptrade.com for credentials
# Covers: Fidelity, Schwab, and other brokerage/investment accounts
# -----------------------------------------------------------------------------
SNAPTRADE_CLIENT_ID=your-snaptrade-client-id
SNAPTRADE_CONSUMER_KEY=your-snaptrade-consumer-key

# -----------------------------------------------------------------------------
# ntfy.sh Push Notifications
# Free/open-source push notification service. Install the ntfy app on iOS/Android.
# See https://ntfy.sh for details.
# -----------------------------------------------------------------------------
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=your-unique-topic-name
NTFY_TOKEN=
